{
    "name": "kode/context",
    "description": "轻量级、高性能的 PHP 协程/纤程上下文管理库，支持分布式多机器部署",
    "keywords": ["context", "coroutine", "fiber", "swoole", "swow", "request-context", "php8", "distributed", "tracing", "上下文", "协程", "纤程", "分布式"],
    "homepage": "https://github.com/kodephp/context",
    "license": "Apache-2.0",
    "version": "2.2.0",
    "authors": [
        {
            "name": "KodePHP",
            "email": "382601296@qq.com"
        }
    ],
    "support": {
        "issues": "https://github.com/kodephp/context/issues",
        "source": "https://github.com/kodephp/context"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Context\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Context\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse src tests --level=max",
        "benchmark": "php benchmark.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
