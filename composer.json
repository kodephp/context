{
    "name": "kode/context",
    "description": "A lightweight, high-performance context management library for PHP coroutine/fiber environments with distributed support",
    "keywords": ["context", "coroutine", "fiber", "swoole", "swow", "request-context", "php8", "distributed", "tracing"],
    "homepage": "https://github.com/kodephp/context",
    "license": "Apache-2.0",
    "version": "2.1.0",
    "authors": [
        {
            "name": "KodePHP",
            "email": "382601296@qq.com"
        }
    ],
    "support": {
        "issues": "https://github.com/kodephp/context/issues",
        "source": "https://github.com/kodephp/context"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Context\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Context\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse src tests --level=max",
        "benchmark": "php benchmark.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
